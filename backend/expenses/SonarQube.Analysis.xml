<SonarQubeAnalysisProperties 
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
    xmlns:xsd="http://www.w3.org/2001/XMLSchema" 
    xmlns="http://www.sonarsource.com/msbuild/integration/2015/1">
  <!-- Project identification -->
  <Property Name="sonar.projectName">Expense Manager - Backend - Expenses</Property>

  <!-- Exclusions for analysis -->
  <Property Name="sonar.exclusions">**/obj/**,**/bin/**,**/*.Designer.cs,**/*.g.cs,**/Migrations/**</Property>

  <!-- Exclusions for coverage -->
  <Property Name="sonar.coverage.exclusions">**/Program.cs,**/Startup.cs,**/Migrations/**,**/EO/**,**/Models/**,**/*.Designer.cs,**/*.g.cs</Property>

  <!-- Coverage report path -->
  <Property Name="sonar.cs.opencover.reportsPaths">coverage/**/*.opencover.xml</Property>
</SonarQubeAnalysisProperties>