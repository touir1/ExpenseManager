<?xml version="1.0" encoding="utf-8"?>
<SonarQubeAnalysisProperties xmlns:xsi="http://www.w3.org" 
                              xmlns:xsd="http://www.w3.org" 
                              xmlns="http://www.sonarsource.com">
  <!-- Project identification -->
  <Property Name="sonar.projectKey">touir:expense-manager:backend:users</Property>
  <Property Name="sonar.projectName">Expense Manager - Backend - Users</Property>

  <!-- Source and test directories -->
  <Property Name="sonar.sources">Touir.ExpenseManager.Users</Property>
  <Property Name="sonar.tests">Touir.ExpenseManager.Users.Tests</Property>

  <!-- Exclusions for analysis -->
  <Property Name="sonar.exclusions">**/obj/**,**/bin/**,**/*.Designer.cs,**/*.g.cs</Property>

  <!-- Exclusions for coverage -->
  <Property Name="sonar.coverage.exclusions">**/Program.cs,**/Startup.cs,**/*.Designer.cs,**/*.g.cs</Property>

  <!-- Coverage report path -->
  <Property Name="sonar.cs.opencover.reportsPaths">coverage/**/*.opencover.xml</Property>
</SonarQubeAnalysisProperties>